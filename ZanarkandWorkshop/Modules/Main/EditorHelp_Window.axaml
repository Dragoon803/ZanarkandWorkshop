<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FFXProjectEditor.EditorHelp_Window"
        Title="Zanarkand Workshop Guide"
        Width="680" Height="620"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,14">
            <TextBlock Text="Zanarkand Workshop Guide" FontSize="25" FontWeight="Bold"/>
            <TextBlock Text="A quick overview of the available editors"
                       FontSize="15" Foreground="#BBBBBB"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#555555" BorderThickness="1"
                Background="#151515" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Visible"
                          HorizontalScrollBarVisibility="Disabled" AllowAutoHide="False">
                <StackPanel Margin="18" Spacing="18" VerticalAlignment="Top"
                            HorizontalAlignment="Stretch">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Monster Editor" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Edits complete monster files, including combat stats, status and elemental properties, loot, rewards, and monster AI. The AI workspace provides translated logic, structured controls, worker and jump navigation, validation, and safe statement editing."
                                   TextWrapping="Wrap" Foreground="#DDDDDD"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Items" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Views and edits the game’s item definitions stored in item.bin."
                                   TextWrapping="Wrap" Foreground="#DDDDDD"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Player &amp; Aeon Commands" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Views and edits commands used by party members and Aeons. These entries come from command.bin."
                                   TextWrapping="Wrap" Foreground="#DDDDDD"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Standard Monster Commands" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Views and edits attacks and commands used by standard, non-boss monsters. These entries come from monmagic1.bin."
                                   TextWrapping="Wrap" Foreground="#DDDDDD"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Boss Commands" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Views and edits commands used by bosses throughout the game. These entries come from monmagic2.bin."
                                   TextWrapping="Wrap" Foreground="#DDDDDD"/>
                    </StackPanel>

                    <Border Height="1" Background="#555555"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Project and connection requirements" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Editors require a valid FFX Master folder. Utilities do not require a Master folder; they work directly with the running game and are available only while FFX is connected."
                                   TextWrapping="Wrap" Foreground="#DDDDDD"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2" Content="Close" Click="Button_Close"
                HorizontalAlignment="Right" Margin="0,14,0,0" Padding="20,7"/>
    </Grid>
</Window>
