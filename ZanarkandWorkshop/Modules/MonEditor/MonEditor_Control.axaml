<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:FFXProjectEditor"
             xmlns:converters="clr-namespace:FFXProjectEditor.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FFXProjectEditor.MonEditor_Control"
			 Name="ThisControl">

	<UserControl.Resources>
		<converters:GameCategory_Converter x:Key="GameCategoryConverter"/>
		<converters:JumpDestinationBrushConverter x:Key="JumpDestinationBrushConverter"/>
		<converters:JumpDestinationForegroundConverter x:Key="JumpDestinationForegroundConverter"/>
	</UserControl.Resources>
	<UserControl.Styles>
		<Style Selector=".compactLower TextBlock">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".compactLower TextBox">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".compactLower Button">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".utilityDock TabItem">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Padding" Value="10,4"/>
		</Style>
		<Style Selector=".compactAiViews TextBlock">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".compactAiViews TextBox">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".compactAiViews Button">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".compactAiViews ComboBox">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".compactAiViews CheckBox">
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector=".compactAiViews ListBox">
			<Setter Property="FontSize" Value="13"/>
		</Style>
	</UserControl.Styles>

	<Grid RowDefinitions="*,Auto" MinHeight="0">

		<!-- Bottom bar -->
		<ContentControl Grid.Row="1" MinHeight="50">
			<Grid ColumnDefinitions="*,Auto" Margin="20,4">
				<Button Grid.Column="0" HorizontalAlignment="Left" Margin="0,2,6,2" Click="Button_RevertVanillaMonster" Background="#6B2525" ToolTip.Tip="Restore the entire monster using your verified Original Game Files, then save it immediately. This replaces all monster data, including stats, loot, and the Battle Script.">Restore Original</Button>
				<WrapPanel Grid.Column="1" Classes="compactLower" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
					<Button Margin="0,2,6,2" Click="Button_RestoreOriginalAi" Background="#6B2525" ToolTip.Tip="Discard all Battle Script changes made since this monster was opened, then save the restored script.">Revert</Button>
					<Button Margin="0,2,6,2" Click="Button_UndoAi" ToolTip.Tip="Undo the most recent Battle Script editing action from this monster's current session">Undo</Button>
					<Button Margin="0,2,6,2" Click="Button_RedoAi" ToolTip.Tip="Redo the most recently undone Battle Script editing action from this monster's current session">Redo</Button>
					<Button Margin="8,2,0,2" Click="Button_Save" BorderThickness="1" BorderBrush="AliceBlue" CornerRadius="5">Save</Button>
				</WrapPanel>
			</Grid>
		</ContentControl>

		<!-- Editor -->
		<TabControl Grid.Row="0" MinHeight="0" SelectedIndex="{Binding SelectorDM.SelectedTab}">

			<!-- STATUS -->
			<TabItem Header="Status">
				<ScrollViewer>
					<StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">

						<Expander Header="Info" IsExpanded="{Binding SelectorDM.InfoExpanded}" HorizontalAlignment="Stretch">
							<StackPanel Orientation="Vertical">
								<Label>Name</Label>
								<TextBox IsReadOnly="True" Text="{Binding MonsterStatSheet.Name}"></TextBox>
								<Label>Sensor</Label>
								<TextBox IsReadOnly="True" Text="{Binding MonsterStatSheet.Sensor}"></TextBox>
								<Label>Scan</Label>
								<TextBox IsReadOnly="True" Text="{Binding MonsterStatSheet.Scan}"></TextBox>
							</StackPanel>
						</Expander>

						<Expander Header="Stats" IsExpanded="{Binding SelectorDM.StatsExpanded}" HorizontalAlignment="Stretch">
							<StackPanel Orientation="Vertical">

								<WrapPanel>
									<StackPanel Width="220" Height="150">
										<local:Property_Template Margin="5" Property_Label="HP Overkill" Property_Value="{Binding MonsterStatSheet.HpOverkill}" BorderWidth="200" ValueBorderWidth="100"/>
									</StackPanel>
									<StackPanel Width="220" Height="150">
										<local:Property_Template Margin="5" Grid.Row="0" Grid.Column="1" Property_Label="HP" Property_Value="{Binding MonsterStatSheet.Hp}" BorderWidth="200" ValueBorderWidth="100"/>
										<local:Property_Template Margin="5" Grid.Row="1" Grid.Column="1" Property_Label="MP" Property_Value="{Binding MonsterStatSheet.Mp}" BorderWidth="200" ValueBorderWidth="100"/>
									</StackPanel>
									<StackPanel Width="220" Height="150">
										<local:Property_Template Margin="5" Grid.Row="0" Grid.Column="2" Property_Label="Strength" Property_Value="{Binding MonsterStatSheet.Strength}" BorderWidth="200" ValueBorderWidth="100"/>
										<local:Property_Template Margin="5" Grid.Row="1" Grid.Column="2" Property_Label="Defense" Property_Value="{Binding MonsterStatSheet.Defense}" BorderWidth="200" ValueBorderWidth="100"/>
									</StackPanel>
									<StackPanel Width="220" Height="150">
										<local:Property_Template Margin="5" Grid.Row="0" Grid.Column="3" Property_Label="Magic" Property_Value="{Binding MonsterStatSheet.Magic}" BorderWidth="200" ValueBorderWidth="100"/>
										<local:Property_Template Margin="5" Grid.Row="1" Grid.Column="3" Property_Label="M. Defense" Property_Value="{Binding MonsterStatSheet.MagicDefense}" BorderWidth="200" ValueBorderWidth="100"/>
									</StackPanel>
									<StackPanel Width="220" Height="150">
										<local:Property_Template Margin="5" Grid.Row="0" Grid.Column="4" Property_Label="Agility" Property_Value="{Binding MonsterStatSheet.Agility}" BorderWidth="200" ValueBorderWidth="100"/>
										<local:Property_Template Margin="5" Grid.Row="1" Grid.Column="4" Property_Label="Luck" Property_Value="{Binding MonsterStatSheet.Luck}" BorderWidth="200" ValueBorderWidth="100"/>
									</StackPanel>
									<StackPanel Width="220" Height="150">
										<local:Property_Template Margin="5" Grid.Row="0" Grid.Column="5" Property_Label="Evasion" Property_Value="{Binding MonsterStatSheet.Evasion}" BorderWidth="200" ValueBorderWidth="100"/>
										<local:Property_Template Margin="5" Grid.Row="1" Grid.Column="5" Property_Label="Accuracy" Property_Value="{Binding MonsterStatSheet.Accuracy}" BorderWidth="200" ValueBorderWidth="100"/>
									</StackPanel>
								</WrapPanel>

							</StackPanel>
						</Expander>

						<Expander Header="Properties" IsExpanded="{Binding SelectorDM.PropertiesExpanded}" HorizontalAlignment="Stretch">
							<StackPanel>
								<WrapPanel>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_Armored}">Armored</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityFractionalDamage}">ImmunityFractionalDamage</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityLife}">ImmunityLife</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunitySensor}">ImmunitySensor</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityScanAgain_Maybe}">ImmunityScanAgain</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityPhysicalDamage}">ImmunityPhysicalDamage</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityMagicDamage}">ImmunityMagicDamage</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityAllDamage}">ImmunityAllDamage</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityDelay}">ImmunityDelay</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunitySlice_Maybe}">ImmunitySlice</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Prop_ImmunityBribe_Maybe}">ImmunityBribe</CheckBox>
								</WrapPanel>
								<WrapPanel HorizontalAlignment="Center">
									<local:Property_Template Margin="5" Property_Label="Poison Damage" Property_Value="{Binding MonsterStatSheet.PoisonDamage}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Doom Counter" Property_Value="{Binding MonsterStatSheet.DoomCount}" BorderWidth="200" ValueBorderWidth="50"/>
								</WrapPanel>
							</StackPanel>
						</Expander>

						<Expander Header="Elemental Weaknesses" IsExpanded="{Binding SelectorDM.ElementalWeaknessesExpanded}" HorizontalAlignment="Stretch">
							<StackPanel>

								<Grid RowDefinitions="*,*,*,*,*" ColumnDefinitions="*,*,*,*,*,*" Width="500">
									<Label Grid.Row="0" Grid.Column="1" Width="100" HorizontalContentAlignment="Center">Fire</Label>
									<Label Grid.Row="0" Grid.Column="2" Width="100" HorizontalContentAlignment="Center">Blizzard</Label>
									<Label Grid.Row="0" Grid.Column="3" Width="100" HorizontalContentAlignment="Center">Thunder</Label>
									<Label Grid.Row="0" Grid.Column="4" Width="100" HorizontalContentAlignment="Center">Water</Label>
									<Label Grid.Row="0" Grid.Column="5" Width="100" HorizontalContentAlignment="Center">Holy</Label>

									<Label Grid.Row="1" Grid.Column="0">Absorb</Label>
									<CheckBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.AbsorbFire}"/>
									<CheckBox Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.AbsorbBlizzard}"/>
									<CheckBox Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.AbsorbThunder}"/>
									<CheckBox Grid.Row="1" Grid.Column="4" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.AbsorbWater}"/>
									<CheckBox Grid.Row="1" Grid.Column="5" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.AbsorbHoly}"/>

									<Label Grid.Row="2" Grid.Column="0">Immune</Label>
									<CheckBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ImmuneFire}"/>
									<CheckBox Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ImmuneBlizzard}"/>
									<CheckBox Grid.Row="2" Grid.Column="3" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ImmuneThunder}"/>
									<CheckBox Grid.Row="2" Grid.Column="4" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ImmuneWater}"/>
									<CheckBox Grid.Row="2" Grid.Column="5" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ImmuneHoly}"/>

									<Label Grid.Row="3" Grid.Column="0">Resist</Label>
									<CheckBox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ResistFire}"/>
									<CheckBox Grid.Row="3" Grid.Column="2" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ResistBlizzard}"/>
									<CheckBox Grid.Row="3" Grid.Column="3" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ResistThunder}"/>
									<CheckBox Grid.Row="3" Grid.Column="4" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ResistWater}"/>
									<CheckBox Grid.Row="3" Grid.Column="5" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.ResistHoly}"/>

									<Label Grid.Row="4" Grid.Column="0">Weak</Label>
									<CheckBox Grid.Row="4" Grid.Column="1" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.WeakFire}"/>
									<CheckBox Grid.Row="4" Grid.Column="2" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.WeakBlizzard}"/>
									<CheckBox Grid.Row="4" Grid.Column="3" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.WeakThunder}"/>
									<CheckBox Grid.Row="4" Grid.Column="4" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.WeakWater}"/>
									<CheckBox Grid.Row="4" Grid.Column="5" HorizontalAlignment="Center" IsChecked="{Binding MonsterStatSheet.ElementalWeakness.WeakHoly}"/>
								</Grid>

							</StackPanel>
						</Expander>

						<Expander Header="Statuses" IsExpanded="{Binding SelectorDM.StatusExpanded}" HorizontalAlignment="Stretch">
							<StackPanel>
								<Label FontSize="20" FontWeight="Bold">Resistances</Label>
								<WrapPanel>
									<local:Property_Template Margin="5" Property_Label="Death" Property_Value="{Binding MonsterStatSheet.StatusResistance.Death}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Zombie" Property_Value="{Binding MonsterStatSheet.StatusResistance.Zombie}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Petrify" Property_Value="{Binding MonsterStatSheet.StatusResistance.Petrify}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Poison" Property_Value="{Binding MonsterStatSheet.StatusResistance.Poison}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="BreakPower" Property_Value="{Binding MonsterStatSheet.StatusResistance.BreakPower}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="BreakMagic" Property_Value="{Binding MonsterStatSheet.StatusResistance.BreakMagic}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="BreakArmor" Property_Value="{Binding MonsterStatSheet.StatusResistance.BreakArmor}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="BreakMental" Property_Value="{Binding MonsterStatSheet.StatusResistance.BreakMental}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Confuse" Property_Value="{Binding MonsterStatSheet.StatusResistance.Confuse}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Berserk" Property_Value="{Binding MonsterStatSheet.StatusResistance.Berserk}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Provoke" Property_Value="{Binding MonsterStatSheet.StatusResistance.Provoke}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Threaten" Property_Value="{Binding MonsterStatSheet.StatusResistance.Threaten}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Sleep" Property_Value="{Binding MonsterStatSheet.StatusResistance.Sleep}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Silence" Property_Value="{Binding MonsterStatSheet.StatusResistance.Silence}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Darkness" Property_Value="{Binding MonsterStatSheet.StatusResistance.Darkness}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Shell" Property_Value="{Binding MonsterStatSheet.StatusResistance.Shell}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Protect" Property_Value="{Binding MonsterStatSheet.StatusResistance.Protect}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Reflect" Property_Value="{Binding MonsterStatSheet.StatusResistance.Reflect}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="NulTide" Property_Value="{Binding MonsterStatSheet.StatusResistance.NulTide}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="NulBlaze" Property_Value="{Binding MonsterStatSheet.StatusResistance.NulBlaze}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="NulShock" Property_Value="{Binding MonsterStatSheet.StatusResistance.NulShock}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="NulFrost" Property_Value="{Binding MonsterStatSheet.StatusResistance.NulFrost}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Regen" Property_Value="{Binding MonsterStatSheet.StatusResistance.Regen}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Haste" Property_Value="{Binding MonsterStatSheet.StatusResistance.Haste}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Slow" Property_Value="{Binding MonsterStatSheet.StatusResistance.Slow}" BorderWidth="200" ValueBorderWidth="50"/>
								</WrapPanel>
								<Label FontSize="20" FontWeight="Bold">Auto</Label>
								<Separator/>
								<Label>Permanent</Label>
								<Separator Opacity="0.2"/>
								<WrapPanel>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Death}">Death</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Zombie}">Zombie</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Petrify}">Petrify</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Poison}">Poison</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_BreakPower}">BreakPower</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_BreakMagic}">BreakMagic</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_BreakArmor}">BreakArmor</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_BreakMental}">BreakMental</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Confuse}">Confuse</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Berserk}">Berserk</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Provoke}">Provoke</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Threaten}">Threaten</CheckBox>
								</WrapPanel>
								<Label>Temporal</Label>
								<Separator Opacity="0.2"/>
								<WrapPanel>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Sleep}">Sleep</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Silence}">Silence</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Shell}">Shell</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Protect}">Protect</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Reflect}">Reflect</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_NulTide}">NulTide</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_NulBlaze}">NulBlaze</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_NulShock}">NulShock</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_NulFrost}">NulFrost</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Regen}">Regen</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Haste}">Haste</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Slow}">Slow</CheckBox>
								</WrapPanel>
								<Label>Special</Label>
								<Separator Opacity="0.2"/>
								<WrapPanel>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Scan}">Scan</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_DistillPower}">DistillPower</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_DistillMana}">DistillMana</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_DistillSpeed}">DistillSpeed</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Unused3_04}">Distill Unused</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_DistillAbility}">DistillAbility</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Shield}">Shield</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Boost}">Boost</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Eject}">Eject</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_AutoLife}">AutoLife</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Curse}">Curse</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Defend}">Defend</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Guard}">Guard</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Sentinel}">Sentinel</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Auto_Doom}">Doom</CheckBox>
								</WrapPanel>
								<Label FontSize="20" FontWeight="Bold">Immunities</Label>
								<Separator/>
								<WrapPanel>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Scan}">Scan</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_DistillPower}">DistillPower</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_DistillMana}">DistillMana</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_DistillSpeed}">DistillSpeed</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Unused3_04}">Distill Unused</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_DistillAbility}">DistillAbility</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Shield}">Shield</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Boost}">Boost</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Eject}">Eject</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_AutoLife}">AutoLife</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Curse}">Curse</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Defend}">Defend</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Guard}">Guard</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Sentinel}">Sentinel</CheckBox>
									<CheckBox Margin="5" Width="200" IsChecked="{Binding MonsterStatSheet.Immunity_Doom}">Doom</CheckBox>
								</WrapPanel>
							</StackPanel>

						</Expander>

						<Expander Header="Menu Abilities" IsExpanded="{Binding SelectorDM.MenuAbilitiesExpanded}" HorizontalAlignment="Stretch">
							<StackPanel>

								<local:GameIndex_Template Margin="5" GameIndex_Label="Forced Ability" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.ForcedAbility}"/>
								<WrapPanel>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 1" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability1}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 2" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability2}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 3" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability3}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 4" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability4}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 5" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability5}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 6" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability6}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 7" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability7}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 8" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability8}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 9" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability9}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 10" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability10}"/>
