													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.WakkaArmors[3]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.WakkaArmors[4]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.WakkaArmors[5]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.WakkaArmors[6]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.WakkaArmors[7]}"/>
												</StackPanel>
											</WrapPanel>
										</TabItem>
										<TabItem Header="Lulu">
											<WrapPanel>
												<StackPanel>
													<Label FontSize="20" FontWeight="Bold">Weapon</Label>
													<Separator/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[0]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[1]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[2]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[3]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[4]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[5]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[6]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluWeapons[7]}"/>
												</StackPanel>
												<StackPanel>
													<Label FontSize="20" FontWeight="Bold">Armor</Label>
													<Separator/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[0]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[1]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[2]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[3]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[4]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[5]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[6]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.LuluArmors[7]}"/>
												</StackPanel>
											</WrapPanel>
										</TabItem>
										<TabItem Header="Rikku">
											<WrapPanel>
												<StackPanel>
													<Label FontSize="20" FontWeight="Bold">Weapon</Label>
													<Separator/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[0]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[1]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[2]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[3]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[4]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[5]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[6]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuWeapons[7]}"/>
												</StackPanel>
												<StackPanel>
													<Label FontSize="20" FontWeight="Bold">Armor</Label>
													<Separator/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[0]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[1]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[2]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[3]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[4]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[5]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[6]}"/>
													<local:GameIndex_Template Margin="5" GameIndex_Label="" IsLabelVisible="False" BorderThickness="0" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RikkuArmors[7]}"/>
												</StackPanel>
											</WrapPanel>
										</TabItem>																				

									</TabControl>
								</Border>
								
							</StackPanel>
						</Expander>
					</StackPanel>

				</ScrollViewer>
			</TabItem>

			<!-- MONSTER ATEL AI -->
			<TabItem Header="Battle Script">
				<Grid RowDefinitions="Auto,*,Auto" Margin="5" MinHeight="0">
					<TextBlock x:Name="AiSummaryText" Grid.Row="0" Text="{Binding AiSummary}" IsVisible="False"/>
					<Grid Grid.Row="1" ColumnDefinitions="480,*" MinHeight="0">
						<Grid.RowDefinitions>
							<RowDefinition Height="190" MinHeight="185"/>
							<RowDefinition Height="6"/>
							<RowDefinition Height="*" MinHeight="150"/>
						</Grid.RowDefinitions>
						<Border Classes="compactAiViews" Grid.Column="0" Grid.Row="0" Margin="0,0,5,0" BorderBrush="Gray" BorderThickness="1" Padding="5" MinHeight="185" ClipToBounds="True">
							<Grid RowDefinitions="Auto,*" MinHeight="0" ClipToBounds="True">
								<Border Grid.Row="0" Background="#111111" BorderBrush="#D95252" BorderThickness="0,0,0,3" Padding="5,3"><TextBlock FontSize="14" FontWeight="Bold" ToolTip.Tip="Select a worker to view only its scripts and instructions.">Workers</TextBlock></Border>
								<ListBox x:Name="AiWorkerList" Grid.Row="1" MinHeight="0" SelectionChanged="AiWorker_SelectionChanged" Tapped="AiWorker_Tapped" ScrollViewer.VerticalScrollBarVisibility="Auto"><ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Display}"/></DataTemplate></ListBox.ItemTemplate></ListBox>
							</Grid>
						</Border>
						<GridSplitter Grid.Column="0" Grid.Row="1" Margin="0,1,5,1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
								ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Background="#666666" Cursor="SizeNorthSouth"/>
						<Border Classes="compactAiViews" Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" Margin="5,0,0,0" BorderBrush="Gray" BorderThickness="1" Padding="5">
							<Grid x:Name="AiLogicViewsGrid">
								<Grid.RowDefinitions>
									<RowDefinition Height="*"/>
									<RowDefinition Height="6"/>
									<RowDefinition Height="*"/>
								</Grid.RowDefinitions>
								<Grid x:Name="AiStatementPane" Grid.Row="0" RowDefinitions="Auto,*" MinHeight="0">
								<Border x:Name="AiStatementHeader" Grid.Row="0" MinHeight="30" Background="#111111" BorderBrush="#D95252" BorderThickness="0,0,0,2" Padding="5,2">
									<Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
										<TextBlock Grid.Column="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" ToolTip.Tip="Select a logic statement to view and edit its complete byte sequence.">Battle Logic</TextBlock>
										<Border Grid.Column="1" Width="1" Height="20" Margin="5,0" Background="#666666"/>
										<WrapPanel x:Name="AiStatementActions" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
											<TextBlock x:Name="AiCopiedStatementText" IsVisible="False"/>
											<Button Margin="0,0,2,0" Padding="5,2" FontSize="12" Click="Button_CopyStatement" ToolTip.Tip="Copy the selected logic statement.">Copy</Button>
											<Button Margin="0,0,2,0" Padding="5,2" FontSize="12" Click="Button_PasteStatement" ToolTip.Tip="Replace the selected logic with the copied statement when their sizes match.">Paste</Button>
											<Button Margin="0,0,2,0" Padding="5,2" FontSize="12" Click="Button_InsertStatementBefore" ToolTip.Tip="Insert the copied statement before the selected logic.">Insert Before</Button>
											<Button Margin="0,0,2,0" Padding="5,2" FontSize="12" Click="Button_InsertStatementAfter" ToolTip.Tip="Insert the copied statement after the selected logic.">Insert After</Button>
											<Button Padding="5,2" FontSize="12" Click="Button_DeleteStatement" Background="#6B2525" ToolTip.Tip="Delete the selected statement when it is safe to do so.">Delete</Button>
										</WrapPanel>
										<CheckBox x:Name="AiHideStatements" Grid.Column="3" Margin="4,0,0,0" VerticalAlignment="Center" Content="Hide" Checked="AiStatementVisibility_Changed" Unchecked="AiStatementVisibility_Changed"/>
									</Grid>
								</Border>
								<ListBox x:Name="AiStatementList" Grid.Row="1" MinHeight="85" ItemsSource="{Binding AiStatements}" FontFamily="Consolas" SelectionChanged="AiStatement_SelectionChanged" Tapped="AiStatement_Tapped" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
									<ListBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding OffsetDisplay}"/><Border Background="{Binding IsJumpDestination, Converter={StaticResource JumpDestinationBrushConverter}}"><TextBlock Text="{Binding FirstByteDisplay}" Foreground="{Binding IsJumpDestination, Converter={StaticResource JumpDestinationForegroundConverter}}"/></Border><TextBlock Text="{Binding RemainingBytesDisplay}" Foreground="#70B7FF"/><TextBlock Text="{Binding Translation}"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
								</ListBox>
								</Grid>
								<GridSplitter x:Name="AiLogicSplitter" Grid.Row="1" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center"
									ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" Background="#666666" Cursor="SizeNorthSouth"/>
								<Grid x:Name="AiInstructionPane" Grid.Row="2" RowDefinitions="Auto,*" MinHeight="0">
								<Border x:Name="AiInstructionHeader" Grid.Row="0" MinHeight="30" Background="#111111" BorderBrush="#D95252" BorderThickness="0,0,0,2" Padding="5,2">
									<Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
										<TextBlock Grid.Column="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" ToolTip.Tip="Choose a single instruction to inspect or modify its operand.">Script Instructions</TextBlock>
										<CheckBox x:Name="AiHideInstructions" Grid.Column="1" VerticalAlignment="Center" Content="Hide" Checked="AiInstructionVisibility_Changed" Unchecked="AiInstructionVisibility_Changed"/>
									</Grid>
								</Border>
								<ListBox x:Name="AiInstructionList" Grid.Row="1" MinHeight="85" ItemsSource="{Binding AiInstructions}" FontFamily="Consolas" SelectionMode="Multiple" SelectionChanged="AiInstruction_SelectionChanged" Tapped="AiInstruction_Tapped" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
									<ListBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding OffsetDisplay}"/><Border Background="{Binding IsJumpDestination, Converter={StaticResource JumpDestinationBrushConverter}}"><TextBlock Text="{Binding FirstByteDisplay}" Foreground="{Binding IsJumpDestination, Converter={StaticResource JumpDestinationForegroundConverter}}"/></Border><TextBlock Text="{Binding RemainingBytesDisplay}" Foreground="#70B7FF"/><TextBlock Text="{Binding CompactSemanticDisplay}"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
								</ListBox>
								</Grid>
							</Grid>
						</Border>
						<Border Grid.Column="0" Grid.Row="2" Margin="0,0,5,0" BorderBrush="Gray" BorderThickness="1" Padding="5" MinWidth="480" MinHeight="150">
						<Grid RowDefinitions="Auto,Auto,*"><Border Grid.Row="0" Background="#111111" BorderBrush="#D95252" BorderThickness="0,0,0,3" Padding="7,5"><TextBlock FontSize="15" FontWeight="Bold">Complete Battle Script (Hex)</TextBlock></Border>
							<Border Grid.Row="1" Background="#111111" ClipToBounds="True" Padding="4,2">
								<TextBlock x:Name="AiHexColumnHeader" FontFamily="Consolas" Foreground="#70B7FF" Text="         00 01 02 03 04 05 06 07 08 09 0A 0B 0C 0D 0E 0F"/>
							</Border>
							<Grid Grid.Row="2">
								<TextBox x:Name="AiHexText" Text="{Binding AiHex}" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas"
									 IsInactiveSelectionHighlightEnabled="True" ClearSelectionOnLostFocus="False"
									 SelectionBrush="#B94A48" SelectionForegroundBrush="White"
									 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
								<TextBox x:Name="AiJumpDestinationText" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Consolas"
									 IsReadOnly="True" IsHitTestVisible="False" Background="Transparent" Foreground="Transparent"
									 IsInactiveSelectionHighlightEnabled="True" ClearSelectionOnLostFocus="False"
									 SelectionBrush="#287FD1" SelectionForegroundBrush="White"
									 ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Hidden"/>
							</Grid></Grid>
						</Border>
					</Grid>
					<TabControl x:Name="AiUtilityTabs" Classes="compactLower utilityDock" Grid.Row="2" MinHeight="150" Margin="0,6,0,0" SelectionChanged="AiUtilityTabs_SelectionChanged">
						<TabItem Header="Script Editor">
							<ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
								<Border BorderBrush="#666666" BorderThickness="1" Background="#111111" Padding="10,7">
									<Grid x:Name="AiEditorPanel" RowDefinitions="Auto,Auto,Auto">
										<WrapPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch">
											<WrapPanel x:Name="AiWorkerEditorPanel" Orientation="Horizontal" IsVisible="False">
												<StackPanel Width="240" Margin="4,0">
													<TextBlock Margin="0,0,0,3">Function:</TextBlock>
													<ComboBox x:Name="AiFunctionOptions" Width="240" Height="28" MinWidth="0" SelectionChanged="AiFunction_SelectionChanged" HorizontalAlignment="Stretch">
														<ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Display}"/></DataTemplate></ComboBox.ItemTemplate>
													</ComboBox>
												</StackPanel>
												<StackPanel Width="192" Margin="4,0">
													<TextBlock Margin="0,0,0,3">Jump:</TextBlock>
													<ComboBox x:Name="AiWorkerJumpOptions" Width="192" Height="28" MinWidth="0" HorizontalAlignment="Stretch" SelectionChanged="AiWorkerJump_SelectionChanged" DropDownClosed="AiWorkerJump_DropDownClosed">
														<ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Display}"/></DataTemplate></ComboBox.ItemTemplate>
													</ComboBox>
												</StackPanel>
												<Button x:Name="AiWorkerJumpButton" Width="90" Height="28" Margin="4,20,4,0" Padding="8,2" Click="Button_GoToWorkerJump">Go to Jump</Button>
											</WrapPanel>
											<StackPanel Width="190" Margin="4,0" IsVisible="{Binding IsVisible, ElementName=AiMeaningOptions}">
												<TextBlock x:Name="AiMeaningLabel" Margin="0,0,0,3" HorizontalAlignment="Left" IsVisible="False">Target:</TextBlock>
												<ComboBox x:Name="AiMeaningOptions" Width="190" HorizontalAlignment="Stretch" IsVisible="False" SelectionChanged="AiMeaning_SelectionChanged" DropDownOpened="AiMeaning_DropDownOpened"/>
											</StackPanel>
											<Button x:Name="AiInstructionJumpButton" Width="105" Margin="4,20,4,0" HorizontalAlignment="Left" Click="Button_JumpToDestination" IsVisible="False">Go to Jump</Button>
											<StackPanel x:Name="AiManualOperandEditor" Width="190" Margin="4,0" Orientation="Vertical" HorizontalAlignment="Left" IsVisible="False">
												<StackPanel Orientation="Horizontal" Margin="0,0,0,3">
											<TextBlock>Manual Editing: (Hex)</TextBlock>
												</StackPanel>
												<TextBox x:Name="AiOperandText" Width="190" Watermark="0x409A" FontFamily="Consolas"/>
											</StackPanel>
										</WrapPanel>
										<StackPanel x:Name="AiFloatEditor" Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="4,6,0,0" IsVisible="False">
											<TextBlock x:Name="AiFloatInfoText" VerticalAlignment="Center" Margin="0,0,8,0">Shared float:</TextBlock>
											<TextBox x:Name="AiFloatValueText" Width="150" Watermark="4.0" FontFamily="Consolas"/>
											<TextBlock x:Name="AiFloatWarningText" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="#FFB35C" FontWeight="Bold"/>
										</StackPanel>
										<StackPanel x:Name="AiGroupEditorPanel" Grid.Row="2" Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Stretch" Margin="0,0,0,0" Spacing="6" IsVisible="False"/>
									</Grid>
								</Border>
							</ScrollViewer>
						</TabItem>
						<TabItem Header="Find &amp; Replace">
							<Border BorderBrush="#666666" BorderThickness="1" Background="#111111" Padding="10">
								<WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
									<Grid ColumnDefinitions="Auto,280,Auto" Margin="0,0,18,6">
										<TextBlock Grid.Column="0" VerticalAlignment="Center">Find bytes:</TextBlock>
										<TextBox x:Name="AiSearchText" Grid.Column="1" Margin="7,0" Text="{Binding AiSearchHex, Mode=TwoWay}" Watermark="AEF2FF AEECFF B51E70 D70000" FontFamily="Consolas"/>
										<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
											<Button Click="Button_FindAiPrevious" ToolTip.Tip="Find and highlight the previous matching byte sequence.">Find Previous &#x2191;</Button>
											<Button Click="Button_FindAi" ToolTip.Tip="Find and highlight the next matching byte sequence.">Find Next &#x2193;</Button>
										</StackPanel>
									</Grid>
									<Grid ColumnDefinitions="Auto,240,Auto" Margin="0,0,0,6">
										<TextBlock Grid.Column="0" VerticalAlignment="Center">Replace with:</TextBlock>
										<TextBox x:Name="AiReplacementText" Grid.Column="1" Margin="7,0" Text="{Binding AiReplacementHex, Mode=TwoWay}" Watermark="AE 00 40" FontFamily="Consolas"/>
										<Button Grid.Column="2" Click="Button_ReplaceAi">Replace All &amp; Validate</Button>
									</Grid>
								</WrapPanel>
							</Border>
						</TabItem>
						<TabItem Header="Messages">
							<Border BorderBrush="#666666" BorderThickness="1" Background="#111111" Padding="10,7">
								<Grid ColumnDefinitions="Auto,Auto,*" VerticalAlignment="Center">
									<TextBlock x:Name="AiValidationResultText" Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
									<TextBlock Grid.Column="1" Margin="0,0,9,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="16">Message:</TextBlock>
									<TextBlock x:Name="AiStatusText" Grid.Column="2" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="{Binding AiStatus}" TextWrapping="Wrap"/>
									<TextBlock x:Name="AiSelectedInstructionText" IsVisible="False" Text=""/>
								</Grid>
							</Border>
						</TabItem>
					</TabControl>
					<Button Grid.Row="2" ZIndex="11" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="385,14,0,0"
							Click="Button_ValidateAi">Check Data Validity</Button>
					<StackPanel x:Name="AiSelectionApplyActions" Classes="compactLower" Grid.Row="2" ZIndex="10"
								Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="5" Margin="0,9,12,0">
						<Button Click="Button_ApplyMeaning" IsVisible="{Binding IsVisible, ElementName=AiMeaningOptions}">Apply Dropdown Change</Button>
						<Button Click="Button_ApplyManualOperand" IsVisible="{Binding IsVisible, ElementName=AiManualOperandEditor}">Apply Manual Changes</Button>
						<Button Click="Button_ApplyFloatValue" IsVisible="{Binding IsVisible, ElementName=AiFloatEditor}">Apply Shared Float</Button>
						<Button x:Name="AiGroupApplyButton" Click="Button_ApplyGroupChanges" IsVisible="False">Apply Group Changes</Button>
					</StackPanel>
				</Grid>
			</TabItem>

		</TabControl>

	</Grid>


</UserControl>
