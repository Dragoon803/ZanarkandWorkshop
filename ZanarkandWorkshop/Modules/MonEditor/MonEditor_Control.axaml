									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 13" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability13}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 14" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability14}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 15" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability15}"/>
									<local:GameIndex_Template Margin="5" GameIndex_Label="Ability 16" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterStatSheet.Ability16}"/>
								</WrapPanel>

							</StackPanel>
						</Expander>

						<Expander Header="Identifiers" IsExpanded="{Binding SelectorDM.IdentifiersExpanded}" HorizontalAlignment="Stretch">
							<StackPanel>
								<WrapPanel>
									<local:Property_Template Margin="5" Property_Label="Monster Id" Property_Value="{Binding MonsterStatSheet.MonsterId}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Arena Id" Property_Value="{Binding MonsterStatSheet.ArenaId}" BorderWidth="200" ValueBorderWidth="50"/>
								</WrapPanel>
								<WrapPanel>
									<local:Property_Template Margin="5" Property_Label="Model Id" Property_Value="{Binding MonsterStatSheet.ModelId}" BorderWidth="200" ValueBorderWidth="50"/>
