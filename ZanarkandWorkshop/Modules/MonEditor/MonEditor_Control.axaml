								</WrapPanel>
								<local:Property_Template Margin="5" HorizontalAlignment="Left" Property_Label="Ctb Icon Id" Property_Value="{Binding MonsterStatSheet.CtbIconId}" BorderWidth="200" ValueBorderWidth="50"/>
							</StackPanel>
						</Expander>

					</StackPanel>
				</ScrollViewer>
			</TabItem>

			<!-- LOOT -->
			<TabItem Header="Loot">
				<ScrollViewer>
					<StackPanel>
						<Expander Header="Stats" IsExpanded="{Binding SelectorDM.LootStatsExpanded}" HorizontalAlignment="Stretch">
							<StackPanel>
								<local:GameIndex_Template Margin="5" GameIndex_Label="Ronso Rage" CategOptions="{Binding CategoryOptions}" GameIndex_Object="{Binding MonsterLoot.RonsoRage}"/>
								<WrapPanel>
									<local:Property_Template Margin="5" Property_Label="Gil" Property_Value="{Binding MonsterLoot.Gil}" BorderWidth="200" ValueBorderWidth="50"/>
								</WrapPanel>
								<WrapPanel>
									<local:Property_Template Margin="5" Property_Label="Ap" Property_Value="{Binding MonsterLoot.Ap}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Ap Overkill" Property_Value="{Binding MonsterLoot.ApOverkill}" BorderWidth="200" ValueBorderWidth="50"/>
								</WrapPanel>
								<WrapPanel>
									<local:Property_Template Margin="5" Property_Label="Zanmato Level" Property_Value="{Binding MonsterLoot.ZanmatoLevel}" BorderWidth="200" ValueBorderWidth="50"/>
								</WrapPanel>
								<WrapPanel>
									<local:Property_Template Margin="5" Property_Label="Gil Steal Amount (x100)" Property_Value="{Binding MonsterLoot.Unk1}" BorderWidth="250" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Monster Arena Price (unused)" Property_Value="{Binding MonsterLoot.Unk2}" BorderWidth="300" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Unk" Property_Value="{Binding MonsterLoot.Unk3}" BorderWidth="200" ValueBorderWidth="50"/>
								</WrapPanel>
							</StackPanel>
						</Expander>

						<Expander Header="Drops" IsExpanded="{Binding SelectorDM.LootDropsExpanded}" HorizontalAlignment="Stretch">
							<StackPanel>
								<StackPanel Orientation="Horizontal">
									<local:Property_Template Margin="5" Property_Label="Drop1 Chance" Property_Value="{Binding MonsterLoot.Drop1Chance}" BorderWidth="200" ValueBorderWidth="50"/>
									<local:Property_Template Margin="5" Property_Label="Drop2 Chance" Property_Value="{Binding MonsterLoot.Drop2Chance}" BorderWidth="200" ValueBorderWidth="50"/>
								</StackPanel>
								<Label FontSize="20" FontWeight="Bold">Drops</Label>
								<Separator/>
								<WrapPanel>
									<local:Loot_Template Margin="5" Loot_Label="Drop 1" CategOptions="{Binding CategoryOptions}" Loot_Object="{Binding MonsterLoot.Drop1}" Loot_Count="{Binding MonsterLoot.Drop1Count}"/>
									<local:Loot_Template Margin="5" Loot_Label="Drop 1 Rare" CategOptions="{Binding CategoryOptions}" Loot_Object="{Binding MonsterLoot.Drop1Rare}" Loot_Count="{Binding MonsterLoot.Drop1RareCount}"/>
								</WrapPanel>

								<WrapPanel>
									<local:Loot_Template Margin="5" Loot_Label="Drop 2" CategOptions="{Binding CategoryOptions}" Loot_Object="{Binding MonsterLoot.Drop2}" Loot_Count="{Binding MonsterLoot.Drop2Count}"/>
									<local:Loot_Template Margin="5" Loot_Label="Drop 2 Rare" CategOptions="{Binding CategoryOptions}" Loot_Object="{Binding MonsterLoot.Drop2Rare}" Loot_Count="{Binding MonsterLoot.Drop2RareCount}"/>
								</WrapPanel>

								<Label FontSize="20" FontWeight="Bold">Drops Overkill</Label>
								<Separator/>
								<WrapPanel>
									<local:Loot_Template Margin="5" Loot_Label="Drop Overkill" CategOptions="{Binding CategoryOptions}" Loot_Object="{Binding MonsterLoot.DropOverkill1}" Loot_Count="{Binding MonsterLoot.DropOverkillCount}"/>
									<local:Loot_Template Margin="5" Loot_Label="Drop Overkill Rare" CategOptions="{Binding CategoryOptions}" Loot_Object="{Binding MonsterLoot.DropOverkill1Rare}" Loot_Count="{Binding MonsterLoot.DropOverkillRareCount}"/>
								</WrapPanel>

								<WrapPanel>
